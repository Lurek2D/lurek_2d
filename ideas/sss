-- Definicja 8 kierunków otoczenia (zgodnie z ruchem wskazówek zegara)
local dirs = {
    {x = 0, y = -1}, -- 1: Góra
    {x = 1, y = -1}, -- 2: Góra-Prawo
    {x = 1, y = 0},  -- 3: Prawo
    {x = 1, y = 1},  -- 4: Dół-Prawo
    {x = 0, y = 1},  -- 5: Dół
    {x = -1, y = 1}, -- 6: Dół-Lewo
    {x = -1, y = 0}, -- 7: Lewo
    {x = -1, y = -1} -- 8: Góra-Lewo
}

-- Funkcja pomocnicza do pobierania koloru jako unikalnego ciągu znaków (klucza)
local function get_pixel_key(image, x, y)
    if x < 0 or x >= image.width or y < 0 or y >= image.height then
        return "OUT_OF_BOUNDS"
    end
    -- Zakładamy, że funkcja zwraca wartości 0-255. Jeśli zwraca 0.0-1.0, pomnóż przez 255.
    local r, g, b = image:getPixel(x, y)
    return string.format("%d,%d,%d", r, g, b)
end

-- Funkcja upraszczająca wielokąt (usuwa punkty leżące na liniach prostych)
local function simplify_polygon(poly)
    if #poly < 3 then return poly end

    local simplified = {}
    table.insert(simplified, poly[1])

    for i = 2, #poly - 1 do
        local p1 = simplified[#simplified]
        local p2 = poly[i]
        local p3 = poly[i + 1]

        -- Iloczyn wektorowy do sprawdzenia współliniowości (collinearity)
        -- Jeśli wynik wynosi 0, punkty leżą na jednej linii prostej
        local cross_product = (p2.y - p1.y) * (p3.x - p2.x) - (p3.y - p2.y) * (p2.x - p1.x)

        if cross_product ~= 0 then
            table.insert(simplified, p2)
        end
    end

    table.insert(simplified, poly[#poly])
    return simplified
end

-- Główna funkcja śledząca kontur pojedynczej prowincji
local function trace_boundary(image, start_x, start_y, target_color)
    local polygon = {}
    local curr_x, curr_y = start_x, start_y
    local bg_x, bg_y = start_x, start_y - 1 -- Ponieważ szukamy od góry, wiemy że nad startem jest tło

    local first_move_x, first_move_y = nil, nil
    local steps = 0
    local max_steps = 50000 -- Zabezpieczenie przed nieskończoną pętlą

    repeat
        -- Znajdź pozycję startową w tabeli kierunków względem obecnego piksela tła
        local start_dir = 1
        for d = 1, 8 do
            if curr_x + dirs[d].x == bg_x and curr_y + dirs[d].y == bg_y then
                start_dir = d
                break
            end
        end

        local found = false
        local last_checked_bg_x, last_checked_bg_y = bg_x, bg_y

        -- Przeszukuj otoczenie zgodnie z ruchem wskazówek zegara
        for i = 0, 7 do
            local check_idx = ((start_dir + i - 1) % 8) + 1
            local nx = curr_x + dirs[check_idx].x
            local ny = curr_y + dirs[check_idx].y

            if get_pixel_key(image, nx, ny) == target_color then
                -- Zapisujemy punkt wielokąta
                table.insert(polygon, {x = curr_x, y = curr_y})

                -- Zapamiętaj pierwszy krok, aby poprawnie zakończyć pętlę (Kryterium Jacoba)
                if not first_move_x then
                    first_move_x, first_move_y = nx, ny
                end

                -- Aktualizacja pozycji
                bg_x, bg_y = last_checked_bg_x, last_checked_bg_y
                curr_x, curr_y = nx, ny
                found = true
                break
            else
                last_checked_bg_x, last_checked_bg_y = nx, ny
            end
        end

        if not found then
            -- Obsługa prowincji jedno-pikselowej
            table.insert(polygon, {x = curr_x, y = curr_y})
            break
        end

        steps = steps + 1

        -- Warunek stopu: wróciliśmy do punktu startowego i zmierzamy w tym samym kierunku
        local returned_to_start = (curr_x == start_x and curr_y == start_y)
        local next_step_matches_first = (first_move_x and dirs[start_dir].x + curr_x == first_move_x and dirs[start_dir].y + curr_y == first_move_y)

    until (returned_to_start and next_step_matches_first) or steps > max_steps

    -- Optymalizacja: usuwamy zbędne punkty z linii prostych
    return simplify_polygon(polygon)
end

-- FUNKCJA GŁÓWNA: Przetwarza cały obraz i zwraca listę prowincji z ich polygonami
function generate_province_polygons(image)
    local provinces = {}
    local starting_points = {}

    -- KROK 1: Skanowanie obrazu w celu znalezienia pierwszego piksela (punktu startowego) dla każdego koloru
    for y = 0, image.height - 1 do
        for x = 0, image.width - 1 do
            local color_key = get_pixel_key(image, x, y)

            -- Ignorujemy czarny kolor (0,0,0), jeśli na Twojej mapie oznacza on "pustkę" / niegrywalny ląd
            if color_key ~= "0,0,0" and color_key ~= "OUT_OF_BOUNDS" then
                if not starting_points[color_key] then
                    -- Ponieważ skanujemy od lewej do prawej, od góry do dołu,
                    -- ten punkt na pewno będzie lewym-górnym skrajem prowincji.
                    starting_points[color_key] = {x = x, y = y}
                end
            end
        end
    end

    -- KROK 2: Generowanie wektorów konturów dla każdej znalezionej prowincji
    for color_key, start_pos in pairs(starting_points) do
        local points = trace_boundary(image, start_pos.x, start_pos.y, color_key)

        provinces[color_key] = {
            color = color_key,
            points = points -- Gotowa lista punktów { {x=..., y=...}, {x=..., y=...}, ... }
        }
    end

    return provinces
end
