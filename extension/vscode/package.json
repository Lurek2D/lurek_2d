    "keybindings": [
      {
        "command": "lurek.runGame",
        "key": "alt+l",
        "when": "editorTextFocus && resourceLangId == lua"
      },
      {
        "command": "lurek.stopGame",
        "key": "shift+alt+l",
        "when": "lurek.gameRunning"
      },
      {
        "command": "lurek.openWiki",
        "key": "f2",
        "when": "editorTextFocus && resourceLangId == lua"
      },
      {
        "command": "lurek.test.all",
        "key": "ctrl+shift+t",
        "when": "workspaceFolderCount > 0"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "lurek.runGame",
          "when": "resourceLangId == lua",
          "group": "lurek@1"
        },
        {
          "command": "lurek.openWiki",
          "when": "resourceLangId == lua",
          "group": "lurek@2"
        },
        {
          "command": "lurek.test.generateForFile",
          "when": "resourceLangId == lua",
          "group": "lurek@3"
        }
      ],
      "explorer/context": [
        {
          "command": "lurek.runGame",
          "when": "explorerResourceIsFolder",
          "group": "lurek@1"
        }
      ],
      "view/title": [
        {
          "command": "lurek.assets.refresh",
          "when": "view == lurek.assetExplorer",
          "group": "navigation"
        },
        {
          "command": "lurek.assets.findMissing",
          "when": "view == lurek.assetExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "lurek.assets.insertPath",
          "when": "view == lurek.assetExplorer && viewItem =~ /^assetItem/",
          "group": "lurek@1"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "lurek.sceneLuaEditor",
        "displayName": "Lurek2D Scene Editor",
        "selector": [
          {
            "filenamePattern": "*.scene.lua"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "lurek2d.tilemap",
        "displayName": "Lurek2D TileMap Editor",
        "selector": [
          {
            "filenamePattern": "*.ltm.json"
          }
        ],
        "priority": "default"
      }
    ],
    "snippets": [
      {
        "language": "lua",
        "path": "./data/snippets.json"
      }
    ],
    "configuration": {
      "title": "Lurek2D Toolkit",
      "properties": {
        "lurek.lurekPath": {
          "type": "string",
          "default": "",
          "description": "Path to lurek2d executable"
        },
        "lurek.srcDir": {
          "type": "string",
          "default": "",
          "description": "Game source subdirectory"
        },
        "lurek.saveOnRun": {
          "type": "boolean",
          "default": true,
          "description": "Save files before running"
        },
        "lurek.diagnostics.deprecationWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show deprecated API warnings"
        },
        "lurek.diagnostics.commonMistakes": {
          "type": "boolean",
          "default": true,
          "description": "Detect common Lurek2D mistakes"
        },
        "lurek.diagnostics.unusedRequires": {
          "type": "boolean",
          "default": true,
          "description": "Flag unused require statements"
        },
        "lurek.diagnostics.assetValidation": {
          "type": "boolean",
          "default": true,
          "description": "Validate asset file paths"
        },
        "lurek.inlayHints.parameterNames": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints"
        },
        "lurek.test.testDir": {
          "type": "string",
          "default": "tests",
          "description": "Test directory path"
        },
        "lurek.test.luaTestDir": {
          "type": "string",
          "default": "tests/lua",
          "description": "Lua test directory"
        },
        "lurek.cag.installOnScaffold": {
          "type": "boolean",
          "default": true,
          "description": "Auto-install AI config on scaffold"
        },
        "lurek.package.outputDir": {
          "type": "string",
          "default": "dist",
          "description": "Build output directory"
        },
        "lurek.debugBridge.port": {
          "type": "number",
          "default": 19740,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Debug bridge TCP port"
        },
        "lurek.debugBridge.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-connect on debug run"
        },
        "lurek.luaVersion": {
          "type": "string",
          "enum": [
            "luajit",
            "5.4"
          ],
          "default": "luajit",
          "description": "Lua runtime version for IntelliSense (LuaJIT or Lua 5.4)"
        },
        "lurek.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show parameter name hints inline"
        },
        "lurek.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Lurek2D-specific diagnostics"
        },
        "lurek.formatting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Lua code formatting"
        },
        "lurek.intellisense.luaStdlib": {
          "type": "boolean",
          "default": true,
          "description": "Include Lua standard library in completions"
        },
        "lurek.intellisense.luajitHints": {
          "type": "boolean",
          "default": true,
          "description": "Show LuaJIT performance optimization hints (table alloc in hot path, string concat in loops, etc.)"
        },
        "lurek.intellisense.patternLibrary": {
          "type": "boolean",
          "default": true,
          "description": "Offer pattern library snippets (state machine, object pool, class, event bus, etc.)"
        },
        "lurek.intellisense.keyNameCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Show key name completions inside input API string arguments (lurek.input.isDown, lurek.keypressed)"
        },
        "lurek.intellisense.easingHoverChart": {
          "type": "boolean",
          "default": true,
          "description": "Show easing curve ASCII chart when hovering over easing function name strings"
        },
        "lurek.intellisense.typeInference": {
          "type": "boolean",
          "default": true,
          "description": "Track return types from lurek.* factory functions and enable method completion on instances"
        },
        "lurek.intellisense.globalWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Warn on implicit global variable writes (prefer local declarations)"
        },
        "lurek.intellisense.unusedAssets": {
          "type": "boolean",
          "default": false,
          "description": "Detect asset files in assets/ that are never referenced in Lua code (may be slow on large projects)"
        },
        "lurek.intellisense.classPatternDetection": {
          "type": "boolean",
          "default": true,
          "description": "Detect OOP class patterns (setmetatable, __index) and enable method completion on class instances"
        },
        "lurek.debugger.port": {
          "type": "number",
          "default": 8172,
          "description": "Default TCP port for Lurek2D debug communication"
        }
      }
    },
    "debuggers": [
      {
        "type": "lurek",
        "label": "Lurek2D",
        "program": "",
        "runtime": "",
        "languages": [
          "lua"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the game directory containing main.lua",
                "default": "${workspaceFolder}"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Stop on the first line of main.lua",
                "default": false
              },
              "luaVersion": {
                "type": "string",
                "description": "Lua runtime version",
                "enum": [
                  "luajit",
                  "5.4"
                ],
                "default": "luajit"
              },
              "debugPort": {
                "type": "number",
                "description": "TCP port for debug communication",
                "default": 8172
              },
              "enginePath": {
                "type": "string",
                "description": "Path to Lurek2D engine executable (auto-detected if not set)"
              },
              "args": {
                "type": "array",
                "description": "Additional arguments to pass to the engine",
                "items": {
                  "type": "string"
                },
                "default": []
              }
            }
          },
          "attach": {
            "properties": {
              "debugPort": {
                "type": "number",
                "description": "TCP port of running Lurek2D engine",
                "default": 8172
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "Lurek2D: Debug Game",
            "description": "Launch and debug a Lurek2D game",
            "body": {
              "type": "lurek",
              "request": "launch",
              "name": "Lurek2D: Debug Game",
              "program": "^\"\\${workspaceFolder}\""
            }
          },
          {
            "label": "Lurek2D: Attach",
            "description": "Attach to a running Lurek2D game",
            "body": {
              "type": "lurek",
              "request": "attach",
              "name": "Lurek2D: Attach",
              "debugPort": 8172
            }
          }
        ]
      }
    ],
    "semanticTokenTypes": [
      {
        "id": "lurekCallback",
        "superType": "function",
        "description": "Lurek2D engine lifecycle callback (init, draw, process, keypressed, etc.)"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "lua",
        "scopes": {
          "lurekCallback": [
            "entity.name.function.lurek-callback.lua",
            "keyword.control.lurek.lua",
            "keyword.control"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "prebuild": "npm run generate-api && npm run generate-snippets && npm run generate-luacats",
    "build": "node esbuild.config.mjs --production",
    "watch": "npm run generate-api && npm run generate-snippets && npm run generate-luacats && node esbuild.config.mjs --watch",
    "test": "node esbuild.config.mjs --test && node ./dist/test/runTest.js",
    "lint": "eslint src --ext ts",
    "generate-api": "npx tsx tools/generate-api-data.ts",
    "generate-snippets": "python ../../tools/snippets/gen_vscode_snippets.py",
    "generate-luacats": "npx tsx tools/generate-luacats.ts",
    "generate-all": "npm run generate-api && npm run generate-snippets && npm run generate-luacats",
    "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/debugadapter": "^1.68.0",
    "@vscode/debugprotocol": "^1.68.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^2.26.0",
    "esbuild": "^0.21.0",
    "eslint": "^8.56.0",
    "glob": "^10.0.0",
    "mocha": "^10.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  }
}
